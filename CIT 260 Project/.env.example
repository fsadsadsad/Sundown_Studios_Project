# CSN Exam Registration — Environment Variables
  # Copy this file to .env and fill in your values
  # The .env file is gitignored and stays on your machine only

  # Gmail address that sends confirmation emails
  GMAIL_ADDRESS=nathanmesfin3@gmail.com

  # Gmail App Password (16 chars, no spaces)
  # How to get one:
  #   1. Go to myaccount.google.com/apppasswords
  #   2. Enable 2-Step Verification if not already on
  #   3. Create a new App Password (name it "CSN")
  #   4. Paste the 16-character code here (no spaces)
  GMAIL_APP_PASSWORD=your_16_char_app_password_here

  # Flask secret key (change to any random string)
  SECRET_KEY=change_this_to_a_random_secret
  